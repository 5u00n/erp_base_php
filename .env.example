# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev):
DATABASE_URL=sqlite:./database/erp.db
# PostgreSQL for production:
# DATABASE_URL=pgsql:host=localhost;port=5432;dbname=erp_base

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_32_chars_minimum_secret
JWT_EXPIRES_IN=7d

# API key HMAC pepper — generate with: openssl rand -hex 32
API_KEY_PEPPER=change_me_api_key_pepper_32_chars

# AES-256-GCM encryption key (32+ chars) — for module secrets / credentials
ENCRYPTION_KEY=change_me_encryption_key_32_chars

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:8000

# ── Seeder ────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123456

# ── Stripe (optional) ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...

# ── VAPID Web Push (optional) ─────────────────────────────────────────────────
# Generate with: vendor/bin/web-push-generate-vapid-keys  (or use Node: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── FCM (optional, legacy) ────────────────────────────────────────────────────
# FCM_SERVER_KEY=
